{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "N2NSVR",
  "version": "0.1.0",
  "identifier": "com.lijunlei.n2n-supernode-launcher",
  "build": {
    "frontendDist": "../src-ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "N2NSVR",
        "width": 560,
        "height": 660,
        "minWidth": 520,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/**/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
